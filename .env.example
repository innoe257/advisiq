# Copy this file to .env and fill in real values for local development.
# Never commit .env — only .env.example is tracked.

# --- Database ---
POSTGRES_USER=advisiq
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=advisiq
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://advisiq:change_me_locally@db:5432/advisiq

# --- Auth / JWT ---
# Generate a real secret with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_a_generated_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Observability (optional) ---
# Leave unset to disable Sentry entirely (default in every environment).
SENTRY_DSN=
